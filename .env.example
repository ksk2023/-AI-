# Copy this file to .env and fill in your real keys.
# .env is gitignored and will never be committed.

# Finance Hub API (primary price data source)
FINANCE_HUB_API_KEY=your_finance_hub_key_here
FINANCE_HUB_BASE_URL=https://api.financehub.example.com/v1

# Alpha Vantage (fundamentals, macro, technicals)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query

# Reserved for later providers
POLYGON_API_KEY=
ALPACA_API_KEY=
ALPACA_API_SECRET=